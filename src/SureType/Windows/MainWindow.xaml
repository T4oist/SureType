<Window x:Class="SureType.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SureType"
        Width="700"
        Height="520"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F8FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock x:Name="AppTitleText" Text="SureType" FontSize="26" FontWeight="SemiBold" Foreground="#FF20242A" />
            <TextBlock x:Name="SubtitleText" Margin="0,6,0,0" Foreground="#FF65707A" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SectionList" SelectionChanged="SectionList_SelectionChanged" Background="Transparent" BorderThickness="0">
                <ListBoxItem x:Name="GeneralNavItem" Padding="10" />
                <ListBoxItem x:Name="GuideNavItem" Padding="10" />
                <ListBoxItem x:Name="PositionNavItem" Padding="10" />
                <ListBoxItem x:Name="TimingNavItem" Padding="10" />
                <ListBoxItem x:Name="StyleNavItem" Padding="10" />
            </ListBox>

            <Border Grid.Column="2" Background="#FFFFFFFF" BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="18">
                <Grid>
                    <StackPanel x:Name="GeneralPanel">
                        <TextBlock x:Name="GeneralTitleText" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock x:Name="GeneralDescriptionText" Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />

                        <Border BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="LanguageLabelText" FontWeight="SemiBold" Foreground="#FF20242A" />
                                <ComboBox x:Name="LanguageComboBox" Width="180" HorizontalAlignment="Left" Margin="0,10,0,0" SelectionChanged="LanguageComboBox_SelectionChanged">
                                    <ComboBoxItem x:Name="ChineseLanguageItem" Tag="Chinese" />
                                    <ComboBoxItem x:Name="EnglishLanguageItem" Tag="English" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <CheckBox x:Name="StartWithWindowsCheckBox" Checked="StartWithWindowsCheckBox_Changed" Unchecked="StartWithWindowsCheckBox_Changed" Foreground="#FF20242A" />
                                <TextBlock x:Name="StartWithWindowsHintText" Margin="24,8,0,0" Foreground="#FF7A858F" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ScrollViewer x:Name="GuidePanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="GuideTitleText" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                            <TextBlock x:Name="GuideDescriptionText" Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />
                            <ItemsControl x:Name="LegendItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="42" Height="42" Background="{Binding Background}" CornerRadius="12" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Symbol}" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#FF20242A" />
                                                    <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="#FF65707A" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel x:Name="PositionPanel" Visibility="Collapsed">
                        <TextBlock x:Name="PositionTitleText" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock x:Name="PositionDescriptionText" Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />
                        <UniformGrid Columns="2" Rows="2">
                            <RadioButton x:Name="TopLeftRadio" Margin="0,0,10,10" Checked="PositionRadio_Checked" />
                            <RadioButton x:Name="TopRightRadio" Margin="0,0,0,10" Checked="PositionRadio_Checked" />
                            <RadioButton x:Name="BottomLeftRadio" Margin="0,0,10,0" Checked="PositionRadio_Checked" />
                            <RadioButton x:Name="BottomRightRadio" Checked="PositionRadio_Checked" />
                        </UniformGrid>
                        <Button x:Name="PreviewPositionButton" Width="130" Height="34" Margin="0,20,0,0" HorizontalAlignment="Left" Click="PreviewButton_Click" />
                    </StackPanel>

                    <StackPanel x:Name="TimingPanel" Visibility="Collapsed">
                        <TextBlock x:Name="TimingTitleText" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock x:Name="TimingDescriptionText" Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />
                        <DockPanel>
                            <TextBlock x:Name="DisplayTimeLabelText" FontWeight="SemiBold" Foreground="#FF20242A" />
                            <TextBlock x:Name="OverlayDurationValue" DockPanel.Dock="Right" Foreground="#FF65707A" />
                        </DockPanel>
                        <Slider x:Name="OverlayDurationSlider" Minimum="0.5" Maximum="5" TickFrequency="0.5" IsSnapToTickEnabled="True" Margin="0,10,0,22" ValueChanged="OverlayDurationSlider_ValueChanged" />
                        <DockPanel>
                            <TextBlock x:Name="CooldownLabelText" FontWeight="SemiBold" Foreground="#FF20242A" />
                            <TextBlock x:Name="FocusCooldownValue" DockPanel.Dock="Right" Foreground="#FF65707A" />
                        </DockPanel>
                        <Slider x:Name="FocusCooldownSlider" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,18" ValueChanged="FocusCooldownSlider_ValueChanged" />
                        <CheckBox x:Name="ShowOnStateChangeCheckBox" Checked="ShowOnStateChangeCheckBox_Changed" Unchecked="ShowOnStateChangeCheckBox_Changed" Foreground="#FF20242A" />
                    </StackPanel>

                    <StackPanel x:Name="StylePanel" Visibility="Collapsed">
                        <TextBlock x:Name="StyleTitleText" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock x:Name="StyleDescriptionText" Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />
                        <RadioButton x:Name="FilledStyleRadio" Margin="0,0,0,10" Checked="StyleRadio_Checked" />
                        <RadioButton x:Name="SoftStyleRadio" Margin="0,0,0,10" Checked="StyleRadio_Checked" />
                        <RadioButton x:Name="MonoStyleRadio" Checked="StyleRadio_Checked" />
                        <Button x:Name="PreviewStyleButton" Width="120" Height="34" Margin="0,20,0,0" HorizontalAlignment="Left" Click="PreviewButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>