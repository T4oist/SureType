<Window x:Class="SureType.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SureType"
        Width="520"
        Height="460"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F8FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="SureType" FontSize="26" FontWeight="SemiBold" Foreground="#FF20242A" />
            <TextBlock Text="A quiet input-state indicator for the moment before typing." Margin="0,6,0,0" Foreground="#FF65707A" />
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="#FFE0E4EA">
            <TabItem Header="Icons">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,16,10,10">
                        <TextBlock Text="Indicator icons" FontSize="17" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock Text="Green means Chinese input, blue means English mode inside a Chinese IME, and gray means English keyboard state." Margin="0,6,0,14" Foreground="#FF65707A" TextWrapping="Wrap" />

                        <ItemsControl x:Name="LegendItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFFFF" BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="40" Height="40" Background="#FFF7F8FA" CornerRadius="8" HorizontalAlignment="Left">
                                                <Image Source="{Binding Asset}" Width="30" Height="30" Stretch="Uniform" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#FF20242A" />
                                                <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="#FF65707A" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Settings">
                <StackPanel Margin="10,16,10,10">
                    <TextBlock Text="Display behavior" FontSize="17" FontWeight="SemiBold" Foreground="#FF20242A" />

                    <Border Background="#FFFFFFFF" BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,10">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Indicator duration" FontWeight="SemiBold" Foreground="#FF20242A" />
                                <TextBlock x:Name="OverlayDurationValue" DockPanel.Dock="Right" Foreground="#FF65707A" />
                            </DockPanel>
                            <Slider x:Name="OverlayDurationSlider" Minimum="0.5" Maximum="5" TickFrequency="0.5" IsSnapToTickEnabled="True" Margin="0,10,0,0" ValueChanged="OverlayDurationSlider_ValueChanged" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFFFF" BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Input-focus cooldown" FontWeight="SemiBold" Foreground="#FF20242A" />
                                <TextBlock x:Name="FocusCooldownValue" DockPanel.Dock="Right" Foreground="#FF65707A" />
                            </DockPanel>
                            <Slider x:Name="FocusCooldownSlider" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,0" ValueChanged="FocusCooldownSlider_ValueChanged" />
                            <TextBlock Text="When several input boxes are focused close together, only the first one shows the indicator." Margin="0,8,0,0" Foreground="#FF7A858F" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFFFF" BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                        <CheckBox x:Name="ShowOnStateChangeCheckBox" Content="Show indicator when input state changes" Checked="ShowOnStateChangeCheckBox_Changed" Unchecked="ShowOnStateChangeCheckBox_Changed" Foreground="#FF20242A" />
                    </Border>

                    <Button Content="Preview" Width="120" Height="34" HorizontalAlignment="Left" Click="PreviewButton_Click" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>