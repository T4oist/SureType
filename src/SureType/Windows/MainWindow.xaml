<Window x:Class="SureType.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SureType Settings"
        Width="680"
        Height="500"
        MinWidth="620"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F8FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="SureType" FontSize="26" FontWeight="SemiBold" Foreground="#FF20242A" />
            <TextBlock Text="Tune where the input logo appears, how long it stays, and how it looks." Margin="0,6,0,0" Foreground="#FF65707A" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SectionList" SelectionChanged="SectionList_SelectionChanged" Background="Transparent" BorderThickness="0">
                <ListBoxItem Content="Guide" Padding="10" />
                <ListBoxItem Content="Position" Padding="10" />
                <ListBoxItem Content="Timing" Padding="10" />
                <ListBoxItem Content="Logo style" Padding="10" />
            </ListBox>

            <Border Grid.Column="2" Background="#FFFFFFFF" BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="18">
                <Grid>
                    <ScrollViewer x:Name="GuidePanel" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Icon guide" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                            <TextBlock Text="Each logo is intentionally short: one symbol, one meaning." Margin="0,6,0,16" Foreground="#FF65707A" />
                            <ItemsControl x:Name="LegendItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#FFE5E8ED" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="42" Height="42" Background="{Binding Background}" CornerRadius="12" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Symbol}" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#FF20242A" />
                                                    <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="#FF65707A" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel x:Name="PositionPanel" Visibility="Collapsed">
                        <TextBlock Text="Logo position" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock Text="Choose which corner SureType uses for the floating logo." Margin="0,6,0,16" Foreground="#FF65707A" />
                        <UniformGrid Columns="2" Rows="2">
                            <RadioButton x:Name="TopLeftRadio" Content="Top left" Margin="0,0,10,10" Checked="PositionRadio_Checked" />
                            <RadioButton x:Name="TopRightRadio" Content="Top right" Margin="0,0,0,10" Checked="PositionRadio_Checked" />
                            <RadioButton x:Name="BottomLeftRadio" Content="Bottom left" Margin="0,0,10,0" Checked="PositionRadio_Checked" />
                            <RadioButton x:Name="BottomRightRadio" Content="Bottom right" Checked="PositionRadio_Checked" />
                        </UniformGrid>
                        <Button Content="Preview position" Width="130" Height="34" Margin="0,20,0,0" HorizontalAlignment="Left" Click="PreviewButton_Click" />
                    </StackPanel>

                    <StackPanel x:Name="TimingPanel" Visibility="Collapsed">
                        <TextBlock Text="Timing" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock Text="Control how long the logo stays visible and how often focusing inputs can show it." Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />
                        <DockPanel>
                            <TextBlock Text="Display time" FontWeight="SemiBold" Foreground="#FF20242A" />
                            <TextBlock x:Name="OverlayDurationValue" DockPanel.Dock="Right" Foreground="#FF65707A" />
                        </DockPanel>
                        <Slider x:Name="OverlayDurationSlider" Minimum="0.5" Maximum="5" TickFrequency="0.5" IsSnapToTickEnabled="True" Margin="0,10,0,22" ValueChanged="OverlayDurationSlider_ValueChanged" />
                        <DockPanel>
                            <TextBlock Text="Input-focus cooldown" FontWeight="SemiBold" Foreground="#FF20242A" />
                            <TextBlock x:Name="FocusCooldownValue" DockPanel.Dock="Right" Foreground="#FF65707A" />
                        </DockPanel>
                        <Slider x:Name="FocusCooldownSlider" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,18" ValueChanged="FocusCooldownSlider_ValueChanged" />
                        <CheckBox x:Name="ShowOnStateChangeCheckBox" Content="Show logo when input state changes" Checked="ShowOnStateChangeCheckBox_Changed" Unchecked="ShowOnStateChangeCheckBox_Changed" Foreground="#FF20242A" />
                    </StackPanel>

                    <StackPanel x:Name="StylePanel" Visibility="Collapsed">
                        <TextBlock Text="Logo style" FontSize="18" FontWeight="SemiBold" Foreground="#FF20242A" />
                        <TextBlock Text="Pick the visual weight that feels easiest to notice without being distracting." Margin="0,6,0,16" Foreground="#FF65707A" TextWrapping="Wrap" />
                        <RadioButton x:Name="FilledStyleRadio" Content="Filled: clear colored tile" Margin="0,0,0,10" Checked="StyleRadio_Checked" />
                        <RadioButton x:Name="SoftStyleRadio" Content="Soft: light background with colored text" Margin="0,0,0,10" Checked="StyleRadio_Checked" />
                        <RadioButton x:Name="MonoStyleRadio" Content="Mono: black and white minimal style" Checked="StyleRadio_Checked" />
                        <Button Content="Preview style" Width="120" Height="34" Margin="0,20,0,0" HorizontalAlignment="Left" Click="PreviewButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>