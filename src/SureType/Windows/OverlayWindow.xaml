<Window x:Class="SureType.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="56"
        Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Opacity="0"
        Visibility="Hidden">
    <Grid>
        <Border Width="46"
                Height="46"
                CornerRadius="16"
                Background="#F7FAFAFA"
                BorderBrush="#22000000"
                BorderThickness="1"
                Effect="{DynamicResource StatusShadow}">
            <Image x:Name="StatusImage"
                   Width="30"
                   Height="30"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>
    </Grid>
</Window>
