<Window x:Class="SureType.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="56"
        Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Opacity="0"
        Visibility="Hidden">
    <Grid>
        <Border x:Name="StatusShell"
                Width="46"
                Height="46"
                CornerRadius="14"
                Background="#FF2E7D67"
                BorderBrush="#22000000"
                BorderThickness="1"
                Effect="{DynamicResource StatusShadow}">
            <TextBlock x:Name="StatusText"
                       Text="?"
                       Foreground="White"
                       FontFamily="Segoe UI, Microsoft YaHei UI"
                       FontSize="17"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>